{
// memo [\s\n\r]+
// "editor.fontFamily": "Noto Serif CJK JP",
// "editor.fontFamily": "Gentium Plus",  // for Greek
// "editor.fontFamily": "monospace",
// "editor.fontFamily": "'JetBrains Mono', 'Consolas', monospace",
// "editor.fontFamily": "'JetBrains Mono MediumItalic'",
// "editor.fontWeight": "300",
// "editor.fontLigatures": true,
"editor.autoIndent": "none",
"editor.wrappingIndent": "none",
"editor.wordWrap": "on",
"editor.fontSize": 20,
"editor.glyphMargin": false,
"editor.guides.indentation": false,
"workbench.colorCustomizations": {
  // "editorUnicodeHighlight.border": "#ff0000", // ハイライトの枠の色
  // "editorWhitespace.foreground": "#444444",    // 半角スペース（ドット）の色
  "editor.findMatchBackground": "#fb21b3",
  "editor.findMatchHighlightBackground": "#288481ed",
  "editor.findRangeHighlightBackground": "#433e3e55"
},
"editor.scrollbar.vertical": "visible",
"editor.minimap.enabled": false,
"inlineChat.affordance": "off",
"editor.snippetSuggestions": "none",
"editor.quickSuggestions": {
  "comments": "off",
  "strings": "off",
  "other": "off"
},
"editor.suggestOnTriggerCharacters": false,
"editor.wordBasedSuggestions": "off",
"editor.quickSuggestionsDelay": 1000000000,
"python-envs.defaultEnvManager": "ms-python.python:venv",
"python-envs.defaultPackageManager": "ms-python.python:pip",
"[python]": {
  "editor.defaultFormatter": "ms-python.black-formatter",
  "editor.formatOnSave": true
},
"[rust]": {
    "editor.defaultFormatter": "statiolake.vscode-rustfmt",
    "editor.formatOnSave": true  //optional
},
// "editor.acceptSuggestionOnEnter": "off",
// "editor.tabCompletion": "off",
// "editor.parameterHints.enabled": false,
// "editor.hover.enabled": "off",

}